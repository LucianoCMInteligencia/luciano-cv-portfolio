{
  "buildCommand": "vite build",
  "installCommand": "pnpm install --frozen-lockfile",
  "framework": "vite",
  "outputDirectory": "dist/public",
  "env": {
    "NODE_ENV": "production"
  },
  "routes": [
    {
      "src": "/.*",
      "methods": ["GET", "HEAD"],
      "dest": "/index.html"
    }
  ]
}
